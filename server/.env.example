# Copy this file to .env and fill in your values
# cp .env.example .env

# ── PostgreSQL (local dev — Railway sets DATABASE_URL automatically) ──────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=medbuddie

# When deploying to Railway / Render, set this instead of the above four vars:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── JWT (use a long random string in production) ─────────────────────────────
JWT_SECRET=replace_with_a_strong_random_secret

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── Facebook OAuth ────────────────────────────────────────────────────────────
FB_APP_ID=your_facebook_app_id
FB_APP_SECRET=your_facebook_app_secret
FB_REDIRECT_URI=http://localhost:3000/facebook-callback

# ── Anthropic AI (get key from console.anthropic.com) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
